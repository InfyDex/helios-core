PORT=8080
DATABASE_URL=postgres://helios:helios@localhost:5432/helios?sslmode=disable
JWT_SECRET=replace_with_at_least_32_random_characters
JWT_EXPIRY=3600
# One client ID (web only), or comma-separated: web,Android,iOS — each must be an OAuth 2.0 Client ID from Google Cloud.
GOOGLE_CLIENT_ID=web_client.apps.googleusercontent.com,android_client.apps.googleusercontent.com,ios_client.apps.googleusercontent.com
